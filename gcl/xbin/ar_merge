#!/bin/bash
#set -x
FLAGS=$1
shift
ARCHIVE=$1
shift
XPWD=$(pwd)

TMPDIR=$(mktemp -d)
while [ $# -gt 0 ] ; do
    case $(basename $1) in
	*.o) cp $1 $TMPDIR;;
	*.go) cp $1 $TMPDIR/$(echo $(basename $1)|sed 's,\.go,.o,g');;
	*.a) cd $TMPDIR && ar x $XPWD/$1 && cd $XPWD;;
	recompile);;
	*) echo Bad arg $1 ; exit 1 ;;
    esac
    shift
done
ar $FLAGS $ARCHIVE $TMPDIR/*.o
rm -rf $TMPDIR
